{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "email"]
    },
    "MealPlan": {
      "title": "MealPlan",
      "description": "Daily meal plan for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "date": { "type": "string", "description": "Date of the meal plan (YYYY-MM-DD)" },
        "meals": {
          "type": "object",
          "description": "Map of meal types to meal data"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date", "meals"]
    },
    "ScannedFood": {
      "title": "ScannedFood",
      "description": "Nutritional data from a scanned food item",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fats": { "type": "number" },
        "confidence": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "calories"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/mealPlans/{planId}": {
      "schema": "MealPlan",
      "description": "User meal plans"
    },
    "/scannedFood/{foodId}": {
      "schema": "ScannedFood",
      "description": "Scanned food logs"
    }
  }
}
